{
  "name": "chat-widget-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/server",
    "packages/dashboard",
    "packages/widget"
  ],
  "scripts": {
    "dev:server": "npm run dev -w packages/server",
    "dev:dashboard": "npm run dev -w packages/dashboard",
    "dev:widget": "npm run dev -w packages/widget",
    "build:dashboard": "npm run build -w packages/dashboard",
    "build:widget": "npm run build -w packages/widget",
    "build": "npm run build:dashboard && npm run build:widget",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:dashboard\" \"npm run dev:widget\"",
    "start": "npm run build && npm run dev:server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
